    "turn": {
      "x": 80,
      "y": 80,
      "edges": [{"target": "goal", "cost": 1}]
    },
    "goal": {"x": 700, "y": 80, "edges": []}
  },
  "edge_actions": [
    {"source": "start", "target": "turn", "key": "w"},
    {"source": "turn", "target": "goal", "key": "d"}
