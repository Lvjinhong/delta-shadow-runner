{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "rootDir": "src",
    "outDir": "dist/server",
    "types": ["node"]
  },
  "include": ["src/core/**/*.ts", "src/server/**/*.ts"],
  "exclude": ["tests", "src/web"]
}
